VITE_APP_ENV=test
VITE_APP_BASE_API=https://test-api.xxx.com
VITE_APP_FILE_BASE_URL=https://test-api.xxx.com
VITE_APP_PORT=5173
VITE_APP_HOST=0.0.0.0
VITE_APP_OPEN=true
VITE_APP_USE_PROXY=true
