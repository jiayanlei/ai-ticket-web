VITE_APP_ENV=production
VITE_APP_BASE_API=https://api.xxx.com
VITE_APP_FILE_BASE_URL=https://api.xxx.com
VITE_APP_PORT=5173
VITE_APP_HOST=0.0.0.0
VITE_APP_OPEN=false
VITE_APP_USE_PROXY=false
VITE_APP_PROXY_TARGET=
VITE_APP_PROXY_REWRITE=/api
VITE_APP_DROP_CONSOLE=true
VITE_APP_DROP_DEBUGGER=true
VITE_APP_SOURCEMAP=false
VITE_APP_GZIP=true
VITE_APP_BUILD_COMPRESS=gzip
VITE_APP_USE_MOCK=false
VITE_APP_PUBLIC_PATH=/
VITE_APP_ROUTER_HISTORY=history
